@startuml 02c_ClassDiagram_BLL
' ============================================================
'  ECOVA -- Class Diagram 2.3: BLL Layer
'  10 interface + 10 implementations + 1 singleton
'  + 2 validators (ContractValidator, ResultValidator)
'  Quan he:
'    (<|..) Realization: Service implements IService
'    (-->) Association: Service --> IRepository (DI inject)
'    (<|--) Generalization: Validator extends AbstractValidator<T>
'  Nguon goc: implementation_plan.md lines 398-463
' ============================================================

skinparam linetype ortho
skinparam ranksep 60
skinparam nodesep 40
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

skinparam class {
    BackgroundColor          #FFFFFF
    BorderColor              #000000
    BorderThickness          1.5
    FontColor                #000000
    FontStyle                bold
    FontSize                 11
    AttributeFontColor       #000000
    AttributeFontSize        10
    HeaderBackgroundColor    #000000
    HeaderFontColor          #FFFFFF
    ArrowColor               #000000
    ArrowFontColor           #000000
    ArrowFontSize            9
}

hide circle
hide stereotypes

' ============================================================
' INTERFACES BLL (10)
' ============================================================

interface "IUserBLL" as IUserBLL {
    + LoginAsync(username, password) : Task<bool>
    + GetFaceIDDataAsync(username) : Task<byte[]?>
    + LoginWithFaceIDAsync(username) : Task<bool>
    + RegisterFaceIDAsync(username, password, faceData) : Task<bool>
    + LogoutAsync() : Task<bool>
    + ResetPasswordAsync(username, newPw) : Task
    + ResetPasswordByEmailAsync(email, newPw) : Task
    + CheckEmailExistsAsync(email) : Task<bool>
    + UpdateProfileAsync(user) : Task
    + UpdateAvatarAsync(userId, data) : Task
}

interface "IAuthService" as IAuthService {
    + GenerateOtp(email) : string
    + ValidateOtpAsync(email, otp) : Task<bool>
    + ChangePasswordByEmailAsync(email, newPW) : Task<bool>
}

interface "IContractService" as IContractService {
    + CreateContractAsync(request) : Task
    + UpdateContractAsync(contract) : Task
    + GetAllContractsAsync() : Task<List<ContractDto>>
    + GetContractCardsAsync() : Task<List<ContractCardDTO>>
    + SearchContractCardsAsync(keyword) : Task<List<ContractCardDTO>>
    + GetContractCardByIdAsync(id) : Task<ContractCardDTO?>
}

interface "ICustomerService" as ICustomerService {
    + GetAllCustomersAsync() : Task<List<CustomerDto>>
    + AddCustomerAsync(customer) : Task
    + UpdateCustomerAsync(customer) : Task
    + CheckTaxCodeExistsAsync(taxCode) : Task<bool>
    + GetCustomerByIdAsync(id) : Task<CustomerDto?>
}

interface "IEmployeeService" as IEmployeeService {
    + AddEmployeeAsync(user) : Task<string>
    + UpdateEmployeeAsync(user) : Task
    + ToggleActiveAsync(userId, isActive) : Task
    + DeleteEmployeeAsync(id) : Task
    + GetEmployeeByIdAsync(id) : Task<UserDTO?>
    + GetAllEmployeesAsync() : Task<List<UserDTO>>
    + SearchEmployeesAsync(keyword) : Task<List<UserDTO>>
    + GenerateNewEmployeeDataAsync(roleId) : Task<(string Code, string ID, string Username)>
}

interface "IPlanningService" as IPlanningService {
    + CreateSamplingAreaAsync(contractId, name, envType) : Task<OrderDTO>
    + DeleteSamplingAreaAsync(orderId) : Task
    + ConfigureSampleLocationsAsync(orderId, samples) : Task
    + CancelSampleAsync(sampleId) : Task
    + SaveSamplingPlanAsync(orderId, items) : Task
    + GetContractListAsync() : Task<List<ContractDisplayDTO>>
    + GetOrdersByContractAsync(contractId) : Task<List<OrderDTO>>
    + GetSamplesByOrderAsync(orderId) : Task<List<SampleDTO>>
    + GetParametersForPlanAsync(envType) : Task<List<SampleParameterPlanDTO>>
    + GetParametersByOrderAsync(orderId) : Task<List<SampleParameterPlanDTO>>
}

interface "ITestingService" as ITestingService {
    + EnterTestResultAsync(result, reason?) : Task
    + GetResultsForSampleAsync(sampleId) : Task<List<TestResultDTO>>
    + GetResultHistoryAsync(resultId) : Task<List<AuditLogDTO>>
}

interface "IExportService" as IExportService {
    + ExportOrderResultToPdfAsync(orderId, customerName, text, path) : Task<string>
    + ExportStructuredPdfAsync(orderId, customerName, address, type, areas, rows, dir, ...) : Task<string>
}

interface "IApprovalService" as IApprovalService {
    + ApproveOrderAsync(orderId, userId) : Task
    + RejectOrderAsync(orderId, userId, reason) : Task
    + IsApprovedAsync(orderId) : Task<bool>
}

interface "INotificationService" as INotificationService {
    + RunDailyDeadlineCheckAsync() : Task
    + GetNotifications() : Task<List<NotificationDTO>>
    + SendBroadcastEmailAsync(...) : Task<(int Sent, int Failed, List<string> FailedEmails)>
}

' ============================================================
' IMPLEMENTATIONS BLL (10)
' ============================================================

class "UserBLL" as UserBLL {
    - _userRepo : IUserRepository
    --
    + (implements IUserBLL)
}

class "AuthService" as AuthService {
    - _userRepo : IUserRepository
    --
    + (implements IAuthService)
}

class "ContractService" as ContractService {
    - _contractRepo  : IContractRepository
    - _validator     : ContractValidator
    - _aiService     : AiIntegrationService
    --
    + (implements IContractService)
}

class "CustomerService" as CustomerService {
    - _customerRepo  : ICustomerRepository
    --
    + (implements ICustomerService)
}

class "EmployeeService" as EmployeeService {
    - _employeeRepo  : IEmployeeRepository
    --
    + (implements IEmployeeService)
}

class "PlanningService" as PlanningService {
    - _sampleRepo    : ISampleRepository
    - _contractRepo  : IContractRepository
    - _orderRepo     : IOrderRepository
    - _paramRepo     : IStandardParameterRepository
    - _planRepo      : ISamplingPlanRepository
    --
    + (implements IPlanningService)
}

class "TestingService" as TestingService {
    - _resultRepo    : ITestResultRepository
    - _auditRepo     : IAuditLogRepository
    - _validator     : ResultValidator
    --
    + (implements ITestingService)
}

class "ExportService" as ExportService {
    ' No constructor params -- calls PdfExportHelper (static)
    --
    + (implements IExportService)
}

class "ApprovalService" as ApprovalService {
    - _orderRepo     : IOrderRepository
    --
    + (implements IApprovalService)
}

class "NotificationService" as NotificationService {
    - _contractRepo  : IContractRepository
    --
    + (implements INotificationService)
}

' ============================================================
' SINGLETON (plan lines 415-436)
' ============================================================

class "AiIntegrationService" as AiIntegrationService <<singleton>> {
    - _mlContext           : MLContext
    - _trainedModel        : ITransformer?
    - _predictionEngine    : PredictionEngine<..>
    - _lock                : object
    - _isModelTrained      : bool  {volatile}
    --
    + PredictRenewal(value, industry, responseTime, violations) : AiPredictionResponse
    + PredictAllCustomers(data) : List<AiPredictionResponse>
    ' inner classes:
    ' ~ ContractRenewalInput   (ML.NET input)
    ' ~ ContractRenewalPrediction (ML.NET output)
}

' ============================================================
' VALIDATORS (plan lines 439-461)
' Generalization: Validator extends AbstractValidator<T> (FluentValidation)
' ============================================================

abstract class "AbstractValidator<T>" as AbstractValidator <<abstract>> {
}

class "ContractValidator" as ContractValidator {
    ' Validates: ContractDto (via CreateContractRequest)
    --
    ' Rules:
    '   ContractId NotEmpty
    '   ContractId MaxLength(50)
    '   CustomerId NotEmpty
    '   ValidTo > ValidFrom
    '   ValidTo > DateTime.Today
    '   TotalContractValue >= 0
}

class "ResultValidator" as ResultValidator {
    ' Validates: TestResultDTO
    --
    ' Rules:
    '   ResultValue >= 0
    '   ParamID NotEmpty
    '   TesterID NotEmpty
}

AbstractValidator <|-- ContractValidator
AbstractValidator <|-- ResultValidator

' ============================================================
' QUAN HE REALIZATION (interface --> implementation)
' ============================================================

IUserBLL             <|.. UserBLL
IAuthService         <|.. AuthService
IContractService     <|.. ContractService
ICustomerService     <|.. CustomerService
IEmployeeService     <|.. EmployeeService
IPlanningService     <|.. PlanningService
ITestingService      <|.. TestingService
IExportService       <|.. ExportService
IApprovalService     <|.. ApprovalService
INotificationService <|.. NotificationService

' ============================================================
' QUAN HE DEPENDENCY (Service --> Repository, per plan)
' ============================================================

UserBLL             --> "IUserRepository"
AuthService         --> "IUserRepository"
ContractService     --> "IContractRepository"
ContractService     --> ContractValidator
ContractService     --> AiIntegrationService
CustomerService     --> "ICustomerRepository"
EmployeeService     --> "IEmployeeRepository"
PlanningService     --> "ISampleRepository"
PlanningService     --> "IContractRepository"
PlanningService     --> "IOrderRepository"
PlanningService     --> "IStandardParameterRepository"
PlanningService     --> "ISamplingPlanRepository"
TestingService      --> "ITestResultRepository"
TestingService      --> "IAuditLogRepository"
TestingService      --> ResultValidator
ApprovalService     --> "IOrderRepository"
NotificationService --> "IContractRepository"
ExportService       ..> "PdfExportHelper" : "<<static call>>"

@enduml
