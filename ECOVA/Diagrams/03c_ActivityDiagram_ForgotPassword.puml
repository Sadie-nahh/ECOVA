@startuml 03c_ActivityDiagram_ForgotPassword
title Forgot Password Process - Activity 3.3 (-> Seq 4.6)
skinparam defaultTextAlignment left
skinparam ActivityBorderColor #000000
skinparam ActivityBackgroundColor #FAFAFA
skinparam ActivityDiamondBorderColor #333333
skinparam ActivityDiamondBackgroundColor #FFFDE7
skinparam ArrowColor #333333
skinparam ActivityBarColor #333333
skinparam FontName Arial
skinparam ActivityFontSize 11
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #BBBBBB
skinparam swimlaneBorderColor #666666

note top
  Source: Login.ForgotPassword.cs
  OTP implemented inline -- does NOT use AuthService.
  Each step maps 100% to code in Login.ForgotPassword.cs.
end note

' ================================================================
' STEP 1: USER CLICKS FORGOT PASSWORD
' ================================================================
|#FFF8E1| User |
start
:Click "Forgot Password" on Login screen;

|#E3F2FD| Login Form <<boundary>> |
:Display email input panel;

|#FFF8E1| User |
:Enter registered email address;

' ================================================================
' STEP 2: CHECK EMAIL EXISTS
' ================================================================
|#F3E5F5| UserBLL <<control>> |
:Check if email exists in the system;
note right
  _userBLL.CheckEmailExistsAsync(email)
  -> UserRepository.GetByEmailAsync(email)
  -> SqlHelper.QuerySingleOrDefaultAsync(
       "sp_GetUserByEmail", {email})
  -> returns UserDTO? (null if not found)
end note

if (Email exists in DB?) then ([No - not found])
  |#E3F2FD| Login Form <<boundary>> |
  :Display error "Email not found in the system";
  back to :Enter registered email address;
else ([Yes - valid email])

  ' ================================================================
  ' STEP 3: GENERATE OTP CODE
  ' ================================================================
  |#E3F2FD| Login Form <<boundary>> |
  :Generate random 6-digit OTP code;
  note right
    RandomNumberGenerator.GetInt32(100000, 1000000)
    _sentOtp = otpNumber.ToString()
    (_sentOtp is a private form field,
     not serialized externally)
  end note

  ' ================================================================
  ' STEP 4: SEND OTP EMAIL
  ' ================================================================
  |#E8F5E9| EmailSmtpHelper <<static>> |
  :Send email containing OTP code to entered address;
  note right
    EmailSmtpHelper.SendEmailAsync(
      email,
      "ECOVA - OTP Code",
      BuildOtpEmailBody(_sentOtp)
    )
    Exact subject: "ECOVA - OTP Code"
    SMTP config: AppConfig.Smtp (host, port, ssl, user, pwd)
  end note

  if (Email sent successfully?) then ([No - SmtpException])
    |#E3F2FD| Login Form <<boundary>> |
    :Display SMTP error message;
    :Unable to send email;
    stop
  else ([Yes - email delivered])

    ' ================================================================
    ' STEP 5: START 5-MINUTE COUNTDOWN TIMER
    ' ================================================================
    |#E3F2FD| Login Form <<boundary>> |
    :Start 5-minute countdown timer;
    note right
      System.Windows.Forms.Timer
      Interval = 1000ms
      Display "OTP valid for MM:SS"
      On expiry: _sentOtp = null
      (invalidates current OTP - any input will fail)
    end note

    ' ================================================================
    ' STEP 6: USER ENTERS OTP
    ' ================================================================
    |#FFF8E1| User |
    :Check email, retrieve OTP code;
    :Enter OTP code into txtForgotOtp field;

    |#E3F2FD| Login Form <<boundary>> |
    :Compare entered OTP with generated OTP;
    note right
      txtForgotOtp.Text.Trim() == _sentOtp
      If expired: _sentOtp == null -> always fails
    end note

    if (OTP correct?) then ([No - wrong or expired])
      :Display error "Invalid OTP code";
      back to :Enter OTP code into txtForgotOtp field;
    else ([Yes - OTP valid])

      ' ================================================================
      ' STEP 7: ENTER NEW PASSWORD
      ' ================================================================
      |#FFF8E1| User |
      :Enter new password;
      :Re-enter password for confirmation;

      ' ================================================================
      ' STEP 8: RESET PASSWORD
      ' ================================================================
      |#F3E5F5| UserBLL <<control>> |
      :Reset new password in database;
      note right
        _userBLL.ResetPasswordByEmailAsync(email, newPassword)
        -> SecurityHelper.HashPassword(newPassword)
           (BCrypt.Net.BCrypt.HashPassword, workFactor=12)
        -> UserRepository.UpdatePasswordByEmailAsync(email, hashedPwd)
           -> SqlHelper.ExecuteNonQueryAsync(
                "sp_ResetPasswordByEmail", {email, hashedPwd})
      end note

      ' ================================================================
      ' STEP 9: NOTIFY SUCCESS
      ' ================================================================
      |#E3F2FD| Login Form <<boundary>> |
      :Display "Password reset successfully";
      :Close Forgot Password form;
      :Redirect to Login screen;
      stop

    endif
  endif
endif

@enduml
