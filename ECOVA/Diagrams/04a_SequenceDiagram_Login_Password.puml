@startuml 04a_SequenceDiagram_Login_Password
title Sequence 4.1 — Login (Password)
skinparam defaultTextAlignment left
skinparam SequenceArrowThickness 1
skinparam SequenceBoxBorderColor #000000
skinparam SequenceLifeLineBorderColor #000000
skinparam SequenceParticipantBackgroundColor #FFFFFF
skinparam SequenceParticipantBorderColor #000000
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #AAAAAA
skinparam FontName Arial
skinparam FontSize 10
skinparam SequenceGroupBorderColor #555555
skinparam SequenceGroupBackgroundColor #F5F5F5

' ── Lifelines (9) — plan: User, Login, LoginThrottleService, UserBLL,
'    UserRepository, SqlHelper, SecurityHelper, AppState, SystemAuditHelper
actor       "User"                   as User
participant ":Login"                 as Login       <<boundary>>
participant ":LoginThrottleService"  as Throttle    <<static>>
participant ":UserBLL"               as UserBLL     <<control>>
participant ":UserRepository"        as UserRepo    <<entity>>
participant ":SqlHelper"             as SqlHelper   <<entity>>
participant ":SecurityHelper"        as SecHelper   <<static>>
participant ":AppState"              as AppState    <<singleton>>
participant ":SystemAuditHelper"     as AuditHelper <<entity>>

' ── Step 1: User submits credentials ────────────────────────────
User -> Login : click "Login" (username, password)
activate Login

Login -> Throttle : IsLockedOut(username, out TimeSpan remaining) [static]
activate Throttle
Throttle --> Login : return false (account not locked)
deactivate Throttle

alt [Account is locked — IsLockedOut = true]
    Login -> Login : Display "Account locked for X min Y sec"
    note right of Login
      User cannot proceed — lock remaining time displayed.
      LoginThrottleService.RemainingAttempts(username) shown.
    end note
else [Not locked — proceed]

    ' ── Step 2: Call UserBLL.LoginAsync ──────────────────────────
    Login -> UserBLL : LoginAsync(username, password)
    activate UserBLL

      UserBLL -> UserRepo : GetByUsernameAsync(username)
      activate UserRepo
        UserRepo -> SqlHelper : QuerySingleOrDefaultAsync(\n"sp_AuthenticateUser", {username})
        activate SqlHelper
        SqlHelper --> UserRepo : return UserDTO\n(PasswordHash, IsActive, RoleID)
        deactivate SqlHelper
      UserRepo --> UserBLL : return UserDTO
      deactivate UserRepo

      UserBLL -> SecHelper : VerifyPassword(inputPwd, UserDTO.PasswordHash) [static]
      activate SecHelper
      note right of SecHelper
        BCrypt.Net.BCrypt.Verify(pwd, hash)
        returns bool
      end note
      SecHelper --> UserBLL : return bool
      deactivate SecHelper

      ' ── Step 3: Branch on result ─────────────────────────────
      alt [Password correct AND IsActive = true]
          UserBLL -> AppState : Instance.CurrentUser = UserDTO [singleton]
          activate AppState
          AppState --> UserBLL
          deactivate AppState

          UserBLL -> AuditHelper : LogAsync(userId, "LOGIN", "User", userId)\n[fire-and-forget Task]
          activate AuditHelper
          AuditHelper --> UserBLL
          deactivate AuditHelper

          UserBLL --> Login : return true
          deactivate UserBLL

          Login -> Login : this.Hide()
          Login -> Login : new MainForm().Show()

      else [Password wrong OR IsActive = false]
          UserBLL --> Login : return false
          deactivate UserBLL

          Login -> Throttle : RecordFailure(username) [static]
          activate Throttle
          note right of Throttle
            _failureCounts[username]++
            If count >= AppConfig.MaxAttempts (default 5):
              LoginThrottleService sets lock timer (LockoutMinutes = 5)
          end note
          Throttle --> Login : (void)
          deactivate Throttle

          alt [Failure count >= 5]
              Login -> Login : Display "Account locked for 5 minutes"
          else [Still under limit]
              Login -> Login : Display wrong password warning\n(remaining attempts shown)
          end
      end

end

deactivate Login

@enduml
