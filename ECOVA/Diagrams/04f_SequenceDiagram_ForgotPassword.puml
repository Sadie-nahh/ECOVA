@startuml 04f_SequenceDiagram_ForgotPassword
title Sequence 4.6 — Forgot Password (OTP Inline — no AuthService)
skinparam defaultTextAlignment left
skinparam SequenceArrowThickness 1
skinparam SequenceBoxBorderColor #000000
skinparam SequenceLifeLineBorderColor #000000
skinparam SequenceParticipantBackgroundColor #FFFFFF
skinparam SequenceParticipantBorderColor #000000
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #AAAAAA
skinparam FontName Arial
skinparam FontSize 10
skinparam SequenceGroupBorderColor #555555
skinparam SequenceGroupBackgroundColor #F5F5F5

note top
  Source: Login.ForgotPassword.cs  (partial class of Login)
  OTP is implemented INLINE in the form — AuthService is NOT used.
  Flow maps 100% to Login.ForgotPassword.cs code.
  _sentOtp is a private form field (never serialized).
end note

' ── Lifelines (5) — plan: User, Login, UserBLL,
'    EmailSmtpHelper (static), SMTP Server (external actor)
actor       "User"             as User
participant ":Login"           as Login     <<boundary>>
participant ":UserBLL"         as UserBLL   <<control>>
participant ":EmailSmtpHelper" as Smtp      <<static>>
actor       "SMTP Server"      as SmtpSrv

' ── Step 1: User clicks Forgot Password, enters email ───────────
User -> Login : click "Forgot Password" link on Login screen
activate Login

Login -> Login : Show email input panel (pnlForgotEmail)

User -> Login : Enter registered email address, click "Send OTP"

' ── Step 2: Verify email exists in system ───────────────────────
Login -> UserBLL : CheckEmailExistsAsync(email)
activate UserBLL
note right of UserBLL
  _userBLL.CheckEmailExistsAsync(email):
    UserRepository.GetByEmailAsync(email)
    -> SqlHelper.QuerySingleOrDefaultAsync(
         "sp_GetUserByEmail", {email})
    -> returns UserDTO? (null if not found)
    -> returns true if UserDTO != null
end note
UserBLL --> Login : return bool (true = exists)
deactivate UserBLL

alt [Email not found — return false]
    Login -> Login : Display error:\n"Email not found in the system"
    Login -> Login : Clear and re-enable email input
end

' ── Step 3: Generate 6-digit OTP inline (no service) ────────────
Login -> Login : int otpNumber =\nRandomNumberGenerator.GetInt32(100000, 1000000)
Login -> Login : _sentOtp = otpNumber.ToString()
note right of Login
  _sentOtp: private string field of Login form.
  Stored in memory only — never persisted to DB.
  Range: 100000 -> 999999 (6 digits guaranteed).
end note
Login -> Login : string body = BuildOtpEmailBody(_sentOtp)
note right of Login
  BuildOtpEmailBody(_sentOtp):
    Returns HTML string with OTP code embedded.
    Exact email subject: "ECOVA - Ma OTP"
    (per AppConfig or hardcoded string in code)
end note

' ── Step 4: Send OTP via SMTP ───────────────────────────────────
Login -> Smtp : SendEmailAsync(\nemail, "ECOVA - Ma OTP", body) [static]
activate Smtp
  Smtp -> SmtpSrv : SmtpClient.SendMailAsync(MailMessage)
  note right of SmtpSrv
    SMTP config from AppConfig.Smtp:
      Host, Port, EnableSsl, Username, Password
  end note
  SmtpSrv --> Smtp : return OK (202 Accepted)
Smtp --> Login : return true (sent successfully)
deactivate Smtp

alt [SmtpException thrown — email delivery failed]
    Login -> Login : Display SMTP error message
    Login -> Login : Disable OTP input (cannot validate without email)
end

' ── Step 5: Start 5-minute countdown timer ──────────────────────
Login -> Login : Start System.Windows.Forms.Timer\n(Interval = 1000ms)\nDisplay countdown label: "OTP valid for MM:SS"
note right of Login
  On Timer.Tick: decrement counter.
  On Timer expiry (300 ticks):
    Timer.Stop()
    _sentOtp = null   <- OTP invalidated
  Any validation after expiry will always fail.
end note

' ── Step 6: User retrieves and enters OTP ───────────────────────
User -> Login : Check email inbox, obtain OTP code
User -> Login : Type OTP into txtForgotOtp field, click "Verify"

Login -> Login : string entered = txtForgotOtp.Text.Trim()\nbool match = (entered == _sentOtp)\nNote: if _sentOtp == null -> always false (expired)

alt [OTP correct — match = true]

    ' ── Step 7: User enters new password ──────────────────────
    Login -> Login : Show new password panel (pnlNewPassword)
    User -> Login : Enter new password + confirm password

    Login -> Login : Validate passwords match and meet policy

    ' ── Step 8: Reset password via UserBLL ─────────────────────
    Login -> UserBLL : ResetPasswordByEmailAsync(email, newPassword)
    activate UserBLL
    note right of UserBLL
      _userBLL.ResetPasswordByEmailAsync(email, newPassword):
        SecurityHelper.HashPassword(newPassword)
          -> BCrypt.Net.BCrypt.HashPassword(pwd, workFactor=12)
          -> returns string hash
        UserRepository.UpdatePasswordByEmailAsync(email, hashedPwd)
          -> SqlHelper.ExecuteNonQueryAsync(
               "sp_ResetPasswordByEmail", {email, hashedPwd})
    end note
    UserBLL --> Login : return (void — success)
    deactivate UserBLL

    Login -> Login : Timer.Stop()
    Login -> Login : _sentOtp = null
    Login -> Login : Display "Password reset successfully"
    Login -> Login : Hide ForgotPassword panels
    Login -> Login : Restore main Login panel (pnlLogin)

else [OTP wrong or expired — match = false]
    Login -> Login : Display error "Invalid or expired OTP code"
    Login -> Login : Keep txtForgotOtp active for retry
end

deactivate Login

@enduml
