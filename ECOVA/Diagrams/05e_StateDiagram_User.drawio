        <mxCell id="22" value="FaceID is used if&lt;br/&gt;IsFaceIDRegistered = 1 AND&lt;br/&gt;IsActive = 1.&lt;br/&gt;Threshold: AppConfig.FaceId.Threshold&lt;br/&gt;(default 0.65).&lt;br/&gt;FaceIdManager.CompareHistogram() ≥ 0.65&lt;br/&gt;→ UserBLL.LoginWithFaceIDAsync()" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=8;align=left;spacingLeft=8;spacingTop=6;spacingRight=6;verticalAlign=top;" vertex="1" parent="1">
