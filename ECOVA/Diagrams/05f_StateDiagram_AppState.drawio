          <mxGeometry relative="1" as="geometry">
            <mxPoint x="781.0" y="802.0" as="sourcePoint" />
            <mxPoint x="745.0" y="651.0" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="26" value="SessionTimeoutService is «static»:&lt;br/&gt;- Started in MainForm constructor:&lt;br/&gt;SessionTimeoutService.Start(minutes: 30, onTimeout: () =&amp;gt; ...)&lt;br/&gt;- Reset() called on any user interaction.&lt;br/&gt;- Stop() called on manual logout." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=8;align=left;spacingLeft=8;spacingTop=6;spacingRight=6;verticalAlign=top;" vertex="1" parent="1">
