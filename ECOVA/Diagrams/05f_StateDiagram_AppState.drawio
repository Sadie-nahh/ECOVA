        <mxCell id="22" value="AppState is «singleton»:&lt;br/&gt;AppState.Instance (double-check lock pattern)&lt;br/&gt;CurrentUser exposes logged-in UserDTO.&lt;br/&gt;RoleID in UserDTO controls role-based UI:&lt;br/&gt;- IsReadOnlyForRole() → Director sees dashboard only.&lt;br/&gt;- Each UC reads AppState.Instance.CurrentUser.RoleID.&lt;br/&gt;[UserDTO.IsActive = false] accounts are REJECTED&lt;br/&gt;at UserBLL.LoginAsync() — they never reach Authenticated." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=8;align=left;spacingLeft=8;spacingTop=6;spacingRight=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="781.0" y="603.0" width="250.0" height="134.0" as="geometry" />
        </mxCell>
        <mxCell id="23" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#888888;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="781.0" y="670.0" as="sourcePoint" />
            <mxPoint x="340.0" y="651.0" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="24" value="LoginThrottleService is «static»:&lt;br/&gt;- _attempts : Dictionary&amp;lt;string, (int Count, DateTime LockUntil)&amp;gt;&lt;br/&gt;- MaxAttempts   = AppConfig.Login.MaxAttempts (default 5)&lt;br/&gt;- LockoutMinutes = AppConfig.Login.LockoutMinutes (default 5)&lt;br/&gt;IsLockedOut(username, out remaining) returns true&lt;br/&gt;when LockUntil &amp;gt; DateTime.Now." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;fontSize=8;align=left;spacingLeft=8;spacingTop=6;spacingRight=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="781.0" y="749.0" width="250.0" height="106.0" as="geometry" />
