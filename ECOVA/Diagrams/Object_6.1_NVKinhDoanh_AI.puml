' ─────────────────────────────────────────────────────────
object "<u>aiResult : AiPredictionResponse</u>" as aiResult {
    CustomerID              = "C01"
    CompanyName             = "Cong ty CP Bao Bi Xanh"
    RenewalProbabilityScore = 0.78
    IsPollutionWarning      = false
    PredictionDetails       = "High renewal probability. Good cooperation frequency, no violations."
}

