' ─────────────────────────────────────────────────────────
' INSTANCE 5  contract1 : ContractDto
'   Source: seed HD-0001 (Contracts table, i=1, cid=C01)
'   SignedDate = DATEADD(DAY,-1,GETDATE()) ~ 2026-04-12
'   ValidTo    = DATEADD(MONTH, 12+1%6, SignedDate) = +13 months
'   TotalValue = 30000000 + (1*1000000) = 31,000,000
'   Status     = 0  [Active: i<=9 AND i<>5 => CASE => 0]
'   CreatedBy  = "U06"  [CASE WHEN @i%2=0 THEN 'U03' ELSE 'U06'; i=1 odd => U06]
'   RenewalLabel = 1  [C01 falls into ELSE branch => 1]
'   DTO class: EnvContract.DTO.Entities.ContractDto
' ─────────────────────────────────────────────────────────
object "<u>contract1 : ContractDto</u>" as contract1 {
    ContractId         = "HD-0001"
    CustomerId         = "C01"
    SignedDate         = "2026-04-12"
    ValidFrom          = "2026-04-12"
    ValidTo            = "2027-05-12"
    Status             = 0
    CreatedBy          = "U06"
    TotalContractValue = 31000000
    IndustryType       = "FoodAndBeverage"
    RenewalLabel       = 1
}

